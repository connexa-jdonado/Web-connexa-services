# Puerto del servidor
PORT=4000

# Origen permitido por CORS (dominio del frontend en su servidor)
FRONTEND_URL=http://localhost:5173

# Destino de los emails del formulario de contacto
CONTACT_TO=contacto@connexaservices.com

# Gmail OAuth2 (recomendado). Si MAIL_REFRESH_TOKEN está definido, se usa OAuth2.
MAIL_USER=
MAIL_CLIENT=
MAIL_SECRET=
MAIL_REFRESH_TOKEN=
MAIL_ACCESS_TOKEN=

# SMTP legacy (fallback si OAuth2 no está configurado). Si ambos están vacíos, solo se loguea.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Connexa Web <no-reply@connexaservices.com>"
